<view class="page-shell">
  <view class="hero">
    <view class="hero-glow"></view>
    <view class="hero-top">
      <view>
        <view class="eyebrow">THE BAZAAR DATABASE</view>
        <view class="title">Bazaar DB</view>
      </view>
      <view class="patch">Patch {{patch}}</view>
    </view>
    <view class="subtitle">物品、技能、商人和事件的随身资料库。搜索名字、英雄、标签或效果，快速筛出你要的卡。</view>
    <view class="search-row">
      <view class="search-box">
        <text class="search-icon">⌕</text>
        <input value="{{keyword}}" placeholder="搜索 Cutlass / Haste / Vanessa" placeholder-class="placeholder" bindinput="onSearchInput" />
      </view>
      <button class="filter-button {{filterOpen ? 'active' : ''}}" bindtap="toggleFilterPanel">筛选</button>
    </view>
  </view>

  <scroll-view scroll-x class="category-scroll" enhanced show-scrollbar="{{false}}">
    <view class="category-row">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-pill {{activeCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="switchCategory"
      >
        <text>{{item.label}}</text>
        <text class="category-count">{{item.count || item.localCount}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{filterOpen}}" class="filter-panel">
    <view class="filter-header">
      <view>
        <view class="filter-title">高级筛选</view>
        <view class="filter-subtitle">按英雄、稀有度、尺寸和标签收窄列表</view>
      </view>
      <button class="clear-button" bindtap="clearFilters">重置</button>
    </view>

    <view class="filter-group">
      <view class="filter-label">英雄</view>
      <view class="chip-row">
        <view wx:for="{{heroes}}" wx:key="*this" class="chip {{activeHero === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectHero">{{item}}</view>
      </view>
    </view>

    <view class="filter-group">
      <view class="filter-label">稀有度</view>
      <view class="chip-row">
        <view wx:for="{{tiers}}" wx:key="*this" class="chip tier-{{item}} {{activeTier === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectTier">{{item}}</view>
      </view>
    </view>

    <view wx:if="{{sizes.length}}" class="filter-group">
      <view class="filter-label">尺寸</view>
      <view class="chip-row">
        <view wx:for="{{sizes}}" wx:key="*this" class="chip {{activeSize === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectSize">{{item}}</view>
      </view>
    </view>

    <view class="filter-group">
      <view class="filter-label">标签</view>
      <view class="chip-row">
        <view wx:for="{{tags}}" wx:key="*this" class="chip {{activeTag === item ? 'active' : ''}}" data-value="{{item}}" bindtap="selectTag">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="result-bar">
    <view>
      <text class="result-number">{{filteredCards.length}}</text>
      <text class="result-text"> 条结果</text>
    </view>
    <view class="source-note">中文数据 · 含远程图片</view>
  </view>

  <view class="card-list">
    <view wx:for="{{filteredCards}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="openCard">
      <view wx:if="{{item.image}}" class="card-art-wrap">
        <image class="card-art" src="{{item.image}}" mode="aspectFit" lazy-load="true"></image>
      </view>
      <view wx:else class="card-rune" style="background: {{item.accent}};">
        <text>{{item.initial}}</text>
      </view>
      <view class="card-body">
        <view class="card-head">
          <view>
            <view class="card-name">{{item.name}}</view>
            <view class="card-meta">{{item.meta}}</view>
          </view>
          <view wx:if="{{item.cooldown}}" class="cooldown">{{item.cooldown}}</view>
        </view>
        <view class="tag-row">
          <text class="tier-badge tier-{{item.tierClass}}">{{item.tier}}</text>
          <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
        </view>
        <view wx:if="{{item.mechanics.length}}" class="mechanic-row">
          <text wx:for="{{item.mechanics}}" wx:key="key" class="mechanic mechanic-{{item.key}}">{{item.label}}</text>
        </view>
        <view class="effect">{{item.effect}}</view>
        <view wx:if="{{item.sourceList.length}}" class="source-row">
          <text class="source-label">来源</text>
          <text wx:for="{{item.sourceList}}" wx:key="name" class="source-chip">{{item.name}} {{item.day}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!filteredCards.length}}" class="empty">
      <view class="empty-title">没有匹配的卡</view>
      <view class="empty-text">试试清空筛选，或者搜索英雄、标签、效果关键词。</view>
      <button class="empty-button" bindtap="clearFilters">清空筛选</button>
    </view>
  </view>

  <view wx:if="{{selectedCard}}" class="modal-mask">
    <view class="modal-backdrop" bindtap="closeCard" catchtouchmove="preventTouchMove"></view>
    <scroll-view scroll-y class="modal" catchtap="noop">
      <view class="modal-accent" style="background: {{selectedCard.accent}};"></view>
      <view class="modal-header">
        <image wx:if="{{selectedCard.image}}" class="modal-art" src="{{selectedCard.image}}" mode="aspectFit"></image>
        <view class="modal-title-block">
          <view class="modal-title">{{selectedCard.name}}</view>
          <view class="modal-meta">{{selectedCard.meta}}</view>
          <view class="tag-row modal-title-tags">
            <text class="tier-badge tier-{{selectedCard.tierClass}}">{{selectedCard.tier}}</text>
            <text wx:for="{{selectedCard.tags}}" wx:key="*this" class="tag">{{item}}</text>
          </view>
        </view>
        <button class="close-button" bindtap="closeCard">×</button>
      </view>

      <view wx:if="{{selectedCard.mechanics.length}}" class="mechanic-row modal-mechanics">
        <text wx:for="{{selectedCard.mechanics}}" wx:key="key" class="mechanic mechanic-{{item.key}}">{{item.label}}</text>
      </view>

      <view class="detail-grid">
        <view class="detail-cell">
          <view class="detail-label">英雄</view>
          <view class="detail-value">{{selectedCard.hero}}</view>
        </view>
        <view class="detail-cell">
          <view class="detail-label">分类</view>
          <view class="detail-value">{{selectedCard.categoryLabel}}</view>
        </view>
        <view wx:if="{{selectedCard.cooldown}}" class="detail-cell">
          <view class="detail-label">冷却</view>
          <view class="detail-value">{{selectedCard.cooldown}}</view>
        </view>
      </view>

      <view class="detail-section">
        <view class="detail-label">效果</view>
        <view class="detail-text">{{selectedCard.effect}}</view>
      </view>
      <view wx:if="{{selectedCard.detailLines.length}}" class="detail-section">
        <view class="detail-label">详情</view>
        <view wx:for="{{selectedCard.detailLines}}" wx:key="*this" class="note-line">{{item}}</view>
      </view>
      <view wx:if="{{selectedCard.sourceList.length}}" class="detail-section">
        <view class="detail-label">获取来源</view>
        <view class="source-list">
          <view wx:for="{{selectedCard.sourceList}}" wx:key="name" class="source-card">
            <text class="source-card-name">{{item.name}}</text>
            <text class="source-card-day">{{item.day}}</text>
          </view>
        </view>
      </view>
      <view class="detail-section">
        <view class="detail-label">源站</view>
        <view class="detail-text link-text">{{selectedCard.url}}</view>
      </view>
    </scroll-view>
  </view>
</view>
