page {
  min-height: 100vh;
  background: #121018;
  color: #f7efe2;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  border-radius: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 24rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 0%, rgba(223, 178, 89, 0.22), transparent 34%),
    radial-gradient(circle at 84% 10%, rgba(103, 129, 220, 0.18), transparent 30%),
    linear-gradient(180deg, #211824 0%, #121018 45%, #0d0b10 100%);
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  border: 1rpx solid rgba(236, 199, 126, 0.24);
  border-radius: 16rpx;
  background: rgba(23, 20, 27, 0.88);
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.28);
}

.hero-glow {
  position: absolute;
  right: -80rpx;
  top: -100rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(213, 153, 70, 0.2);
}

.hero-top {
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.eyebrow {
  margin-bottom: 8rpx;
  color: #d8aa63;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  color: #fff6df;
  font-size: 56rpx;
  font-weight: 800;
}

.patch {
  max-width: 220rpx;
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(216, 170, 99, 0.35);
  border-radius: 10rpx;
  color: #f5d8a0;
  font-size: 22rpx;
  text-align: right;
  background: rgba(11, 9, 13, 0.46);
}

.subtitle {
  position: relative;
  margin-top: 20rpx;
  color: #cfc2ab;
  font-size: 27rpx;
  line-height: 1.55;
}

.search-row {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.search-box {
  flex: 1;
  height: 78rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(240, 210, 157, 0.24);
  border-radius: 12rpx;
  background: rgba(7, 6, 9, 0.54);
  box-sizing: border-box;
}

.search-icon {
  color: #d8aa63;
  font-size: 34rpx;
  font-weight: 700;
}

.search-box input {
  flex: 1;
  height: 78rpx;
  color: #fff8e8;
  font-size: 27rpx;
}

.placeholder {
  color: #776e63;
}

.filter-button,
.clear-button,
.empty-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(216, 170, 99, 0.34);
  border-radius: 12rpx;
  color: #f7d491;
  font-size: 26rpx;
  background: rgba(216, 170, 99, 0.1);
}

.filter-button.active,
.clear-button:active,
.empty-button:active {
  background: rgba(216, 170, 99, 0.22);
}

.category-scroll {
  margin: 26rpx -24rpx 0;
  white-space: nowrap;
}

.category-row {
  display: flex;
  gap: 14rpx;
  padding: 0 24rpx;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 66rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #d5c8b4;
  font-size: 25rpx;
  background: rgba(255, 255, 255, 0.05);
}

.category-pill.active {
  border-color: rgba(216, 170, 99, 0.55);
  color: #fff3d7;
  background: rgba(216, 170, 99, 0.16);
}

.category-count {
  min-width: 34rpx;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  color: #1c1511;
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
  background: #d8aa63;
}

.filter-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(25, 23, 31, 0.92);
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.filter-title {
  color: #fff4dc;
  font-size: 30rpx;
  font-weight: 800;
}

.filter-subtitle {
  margin-top: 6rpx;
  color: #978b7c;
  font-size: 23rpx;
}

.clear-button {
  height: 58rpx;
  padding: 0 18rpx;
  font-size: 23rpx;
}

.filter-group {
  margin-top: 24rpx;
}

.filter-label {
  margin-bottom: 14rpx;
  color: #d8aa63;
  font-size: 23rpx;
  font-weight: 800;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 10rpx;
  color: #cdbfae;
  font-size: 23rpx;
  background: rgba(255, 255, 255, 0.05);
}

.chip.active {
  border-color: rgba(216, 170, 99, 0.58);
  color: #fff7e6;
  background: rgba(216, 170, 99, 0.2);
}

.result-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 26rpx 2rpx 18rpx;
}

.result-number {
  color: #f6c46f;
  font-size: 36rpx;
  font-weight: 900;
}

.result-text,
.source-note {
  color: #9d9284;
  font-size: 23rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.card {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(26, 24, 32, 0.9);
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.18);
}

.card:active {
  transform: scale(0.99);
}

.card-rune {
  flex: 0 0 84rpx;
  width: 84rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #fff7e7;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: inset 0 -18rpx 30rpx rgba(0, 0, 0, 0.18);
}

.card-art-wrap {
  flex: 0 0 96rpx;
  width: 96rpx;
  height: 116rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1rpx solid rgba(216, 170, 99, 0.28);
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.2);
}

.card-art {
  width: 96rpx;
  height: 116rpx;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.card-name {
  color: #fff7e9;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.2;
}

.card-meta,
.modal-meta {
  margin-top: 7rpx;
  color: #9f9586;
  font-size: 22rpx;
}

.cooldown {
  flex: 0 0 auto;
  padding: 8rpx 10rpx;
  border-radius: 8rpx;
  color: #1a1512;
  font-size: 19rpx;
  font-weight: 900;
  background: #e0b76d;
}

.tag-row,
.modal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.tag {
  padding: 6rpx 10rpx;
  border-radius: 7rpx;
  color: #e7d4b3;
  font-size: 20rpx;
  background: rgba(216, 170, 99, 0.14);
}

.tier-badge {
  padding: 6rpx 11rpx;
  border-radius: 7rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #171117;
}

.tier-bronze {
  background: #b57a4c;
}

.tier-silver {
  background: #bac0c8;
}

.tier-gold {
  background: #e1b85d;
}

.tier-diamond {
  color: #0e2531;
  background: #83d5e8;
}

.tier-legendary {
  color: #25120b;
  background: #ee8d50;
}

.tier-unknown {
  color: #f2e5cf;
  background: #645a66;
}

.mechanic-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.mechanic {
  position: relative;
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 4rpx 10rpx 4rpx 28rpx;
  border-radius: 999rpx;
  color: #f8efe4;
  font-size: 20rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.08);
}

.mechanic::before {
  content: "";
  position: absolute;
  left: 10rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 0 0 12rpx currentColor;
}

.mechanic-crit,
.mechanic-damage {
  color: #ff7d69;
}

.mechanic-slow,
.mechanic-freeze {
  color: #8ad8ff;
}

.mechanic-haste,
.mechanic-charge,
.mechanic-flying {
  color: #f2ca66;
}

.mechanic-shield {
  color: #8eb0ff;
}

.mechanic-burn {
  color: #ff935c;
}

.mechanic-poison {
  color: #8cd36f;
}

.mechanic-heal,
.mechanic-health,
.mechanic-regen {
  color: #74d6a2;
}

.mechanic-ammo,
.mechanic-gold {
  color: #e8c36c;
}

.effect {
  margin-top: 14rpx;
  color: #e7dccb;
  font-size: 25rpx;
  line-height: 1.45;
}

.source-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
}

.source-label {
  color: #9b8b78;
  font-size: 21rpx;
  font-weight: 800;
}

.source-chip {
  max-width: 100%;
  padding: 6rpx 10rpx;
  border: 1rpx solid rgba(216, 170, 99, 0.22);
  border-radius: 8rpx;
  color: #cbb999;
  font-size: 20rpx;
  background: rgba(216, 170, 99, 0.08);
}

.empty {
  padding: 60rpx 32rpx;
  border: 1rpx dashed rgba(216, 170, 99, 0.28);
  border-radius: 16rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.04);
}

.empty-title {
  color: #fff2d7;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-text {
  margin-top: 12rpx;
  color: #a89b8b;
  font-size: 24rpx;
  line-height: 1.45;
}

.empty-button {
  width: 220rpx;
  margin: 28rpx auto 0;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.58);
  box-sizing: border-box;
}

.modal {
  position: relative;
  overflow-y: auto;
  width: 100%;
  max-height: 82vh;
  padding: 28rpx;
  border: 1rpx solid rgba(216, 170, 99, 0.22);
  border-radius: 20rpx;
  background: #191720;
  box-sizing: border-box;
}

.modal-accent {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 8rpx;
}

.modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.modal-art {
  flex: 0 0 132rpx;
  width: 132rpx;
  height: 156rpx;
  border: 1rpx solid rgba(216, 170, 99, 0.28);
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.24);
}

.modal-title {
  color: #fff6e1;
  font-size: 40rpx;
  font-weight: 900;
}

.modal-title-block {
  flex: 1;
  min-width: 0;
}

.modal-title-tags {
  margin-top: 16rpx;
}

.modal-mechanics {
  margin-top: 22rpx;
}

.close-button {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #f4d397;
  font-size: 44rpx;
  background: rgba(255, 255, 255, 0.07);
}

.detail-section {
  margin-top: 26rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.detail-cell {
  padding: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.05);
}

.detail-label {
  margin-bottom: 10rpx;
  color: #d8aa63;
  font-size: 23rpx;
  font-weight: 800;
}

.detail-text,
.detail-value,
.note-line {
  color: #eadfce;
  font-size: 26rpx;
  line-height: 1.48;
}

.detail-value {
  font-weight: 800;
}

.source-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.source-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(216, 170, 99, 0.18);
  border-radius: 12rpx;
  background: rgba(216, 170, 99, 0.07);
}

.source-card-name {
  color: #f0dfc2;
  font-size: 25rpx;
  font-weight: 800;
}

.source-card-day {
  flex: 0 0 auto;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
  color: #1c1511;
  font-size: 21rpx;
  font-weight: 900;
  background: #d8aa63;
}

.link-text {
  color: #d8aa63;
  word-break: break-all;
}

.note-line {
  position: relative;
  padding-left: 24rpx;
  margin-top: 8rpx;
}

.note-line::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #d8aa63;
}
